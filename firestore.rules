rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper to check if user is logged in
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // User profile rules: Anyone can create (referral registration), authenticated users can read/update/delete
    match /users/{userId} {
      allow create: if true;
      allow read, update, delete: if isAuthenticated();
    }
    
    // Clients rules: Anyone can create (referral form), authenticated users can read/update/delete
    match /clients/{clientId} {
      allow create: if true;
      allow read, update, delete: if isAuthenticated();
    }
    
    // Commissions rules: Authenticated users can read/write commissions
    match /commissions/{commissionId} {
      allow read, write: if isAuthenticated();
    }
    
    // Dossier leads rules: Anyone can create a lead (public form), only authenticated users can read/update/delete
    match /dossier_leads/{leadId} {
      allow create: if true;
      allow read, update, delete: if isAuthenticated();
    }
  }
}
